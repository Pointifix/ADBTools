{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "webpack",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*webpack.*$",
          "endsPattern": "^.*compiled successfully.*$"
        },
        "pattern": {
          "regexp": "^$"
        }
      },
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "compile",
      "type": "npm",
      "script": "compile",
      "problemMatcher": {
        "owner": "webpack",
        "pattern": {
          "regexp": "^$"
        }
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "never"
      }
    }
  ]
}
