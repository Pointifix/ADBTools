{
  "name": "adbtools",
  "displayName": "ADBTools",
  "description": "Android Debug Bridge Tools Editor Extension",
  "version": "0.0.2",
  "publisher": "pointifix",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pointifix/ADBTools.git"
  },
  "author": "Pointifix",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onFileSystem:adb"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "adbtools.filterLogs",
        "title": "ADB Tools: Filter Device Logs"
      },
      {
        "command": "adbtools.openDashboard",
        "title": "ADB Tools: Open Dashboard"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "adbtools.terminalProfile",
          "title": "ADB Shell",
          "icon": "terminal"
        }
      ]
    },
    "configuration": {
      "title": "ADB Tools",
      "properties": {
        "adbtools.dashboardCommands": {
          "type": "array",
          "default": [
            {
              "name": "Reboot",
              "command": "reboot"
            },
            {
              "name": "List Data",
              "command": "ls -al /data"
            }
          ],
          "description": "Commands to display as buttons in the ADB Dashboard."
        },
        "adbtools.maxLogLines": {
          "type": "integer",
          "default": 10000,
          "description": "The maximum number of log lines to keep for each device. Older lines will be removed to save memory."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "rm -rf out && webpack --mode production",
    "watch": "webpack --mode development --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "package": "mkdir -p releases && npx @vscode/vsce package --out releases/ --skip-license --allow-missing-repository",
    "tag": "bash -c 'read -p \"Enter version tag (e.g. v1.0.0): \" VERSION && git push && git tag $VERSION && git push origin $VERSION'"
  },
  "devDependencies": {
    "@types/flexsearch": "^0.7.42",
    "@types/node": "18.x",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vscode/test-cli": "^0.0.6",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.3.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "flexsearch": "^0.8.212"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "undici": "5.28.4"
  }
}